{
  "name": "stellar-synapse",
  "version": "0.2.48",
  "description": "Stellar Synapse - modular LIS instrument integration middleware for laboratory analyzers (Maglumi X3, MAGICL 6000, Beckman Coulter) interfacing with the Noble LISTEC LIS.",
  "main": "./out/main/index.js",
  "author": "Stellar Synapse",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "build:win": "node scripts/build-installer.mjs",
    "icon": "node scripts/gen-icon.mjs",
    "installer": "node scripts/build-installer.mjs",
    "build:win:dir": "npm run build && electron-builder --win --dir --x64 --config electron-builder.yml",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "verify:mindray": "esbuild scripts/verify-mindray.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-mindray.mjs && node scripts/.verify-mindray.mjs",
    "verify:presets": "esbuild scripts/verify-presets.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-presets.mjs && node scripts/.verify-presets.mjs",
    "verify:magicl": "esbuild scripts/verify-magicl.ts --bundle --platform=node --format=esm --outfile=scripts/.verify-magicl.mjs && node scripts/.verify-magicl.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "mssql": "^11.0.1",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/mssql": "^12.3.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.417.0",
    "postcss": "^8.4.40",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "zustand": "^4.5.4"
  },
  "allowScripts": {
    "electron@31.7.7": true,
    "esbuild@0.21.5": true,
    "@serialport/bindings-cpp": false
  }
}
